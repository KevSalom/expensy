OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Auth (name + password, JWT).
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-hex
# Generate password_hash with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
USERS_JSON=[{"name":"kev","password_hash":"$2b$12$..."},{"name":"meli","password_hash":"$2b$12$..."}]
DEMO_PASSWORD_HASH=$2b$12$...

# Legacy tokens (no longer required; left for backwards compatibility).
PERSONAL_API_TOKEN=personal-token
DEMO_API_TOKEN=demo-token

AIRTABLE_PERSONAL_PAT=pat...
AIRTABLE_DEMO_PAT=pat...
AIRTABLE_PERSONAL_BASE_ID=app...
AIRTABLE_DEMO_BASE_ID=app...
AIRTABLE_EXPENSES_TABLE_ID=tbl...

CORS_ALLOWED_ORIGINS=http://localhost:5173
